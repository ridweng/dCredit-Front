# dCredit — Root environment variables
# Copy to .env and fill in values. Never commit .env to version control.
#
# Each app also has its own .env.example:
#   apps/app-api/.env.example
#   apps/admin-api/.env.example
#   apps/mobile/.env.example

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dcredit

# ─── PostgreSQL (matches docker-compose.yml defaults) ─────────────────────────
POSTGRES_DB=dcredit
POSTGRES_USER=dcredit
POSTGRES_PASSWORD=dcredit_dev_password
DATABASE_URL=postgresql://dcredit:dcredit_dev_password@localhost:5433/dcredit

# ─── NestJS APIs ──────────────────────────────────────────────────────────────
APP_API_PORT=3001
ADMIN_API_PORT=3002
NODE_ENV=development
DATABASE_LOGGING=false
DATABASE_SSL=false

# ─── Mailpit ──────────────────────────────────────────────────────────────────
# SMTP: localhost:1025
# Web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
MAIL_FROM=noreply@dcredit.local

# ─── Auth / Email verification ────────────────────────────────────────────────
APP_API_URL=http://localhost:3001
ADMIN_API_URL=http://localhost:3002
JWT_SECRET=dev-only-change-me-secret
JWT_EXPIRES_IN=1h

# ─── Mobile app ───────────────────────────────────────────────────────────────
# Replace localhost with your machine LAN IP when testing on a real device.
EXPO_PUBLIC_API_URL=http://localhost:3001
