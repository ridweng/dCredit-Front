# dCredit — Root environment variables
# Copy to .env and fill in values. Never commit .env to version control.
#
# Each app also has its own .env.example:
#   apps/api/.env.example
#   apps/web/.env.example
#   apps/mobile/.env.example

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=dcredit

# ─── PostgreSQL (matches docker-compose.yml defaults) ─────────────────────────
POSTGRES_DB=dcredit
POSTGRES_USER=dcredit
POSTGRES_PASSWORD=dcredit_dev_password
DATABASE_URL=postgresql://dcredit:dcredit_dev_password@localhost:5432/dcredit

# ─── NestJS API ───────────────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# ─── Web app ──────────────────────────────────────────────────────────────────
WEB_PORT=5173

# ─── Mailpit ──────────────────────────────────────────────────────────────────
# SMTP: localhost:1025
# Web UI: http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
