# Root Docker Compose environment
# Copy this file to .env before running docker compose.

COMPOSE_PROJECT_NAME=dcredit

# PostgreSQL
POSTGRES_DB=dcredit
POSTGRES_USER=dcredit
POSTGRES_PASSWORD=dcredit_dev_password
POSTGRES_PORT=5433

# Public service ports
APP_API_PORT=3001
ADMIN_API_PORT=3002
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Shared auth / mail
NODE_ENV=development
MAIL_FROM=noreply@dcredit.local
JWT_SECRET=dev-only-change-me-secret-was-changed?!
JWT_EXPIRES_IN=1h
