# Server
NODE_ENV=development
PORT=3001
DATABASE_LOGGING=false
DATABASE_SSL=false

# PostgreSQL — matches the docker-compose service
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_NAME=dcredit
DATABASE_USER=dcredit
DATABASE_PASSWORD=dcredit_dev_password

# Full connection URL (alternative to individual vars)
DATABASE_URL=postgresql://dcredit:dcredit_dev_password@127.0.0.1:5433/dcredit

# SMTP — Mailpit for local dev (real credentials in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@dcredit.local

# Public API origin and mobile/local origins
APP_API_URL=http://localhost:3001
ADMIN_UI_ORIGIN=http://localhost:3002
CORS_ORIGINS=http://localhost:19000,http://localhost:19006,http://127.0.0.1:19000,http://127.0.0.1:19006,http://localhost:3002

# JWT
JWT_SECRET=dev-only-change-me-secret
JWT_EXPIRES_IN=1h
