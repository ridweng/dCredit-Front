{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "!{projectRoot}/node_modules/**/*",
      "!{projectRoot}/dist/**/*",
      "!{projectRoot}/.expo/**/*",
      "!{projectRoot}/coverage/**/*",
      "sharedGlobals"
    ],
    "production": ["default"],
    "sharedGlobals": [
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/pnpm-workspace.yaml",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/tsconfig.json",
      "{workspaceRoot}/docker-compose.yml",
      "{workspaceRoot}/.env.example"
    ]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "inputs": ["default", "^default"],
      "cache": true
    },
    "dev": {
      "cache": false
    },
    "ios": {
      "cache": false
    },
    "android": {
      "cache": false
    },
    "start-prod": {
      "dependsOn": ["build"],
      "cache": false
    },
    "migration-generate": {
      "cache": false
    },
    "migration-run": {
      "cache": false
    },
    "migration-revert": {
      "cache": false
    },
    "seed": {
      "cache": false
    },
    "db-reset": {
      "cache": false
    },
    "push": {
      "cache": false
    },
    "push-force": {
      "cache": false
    },
    "codegen": {
      "cache": false
    },
    "test": {
      "cache": false
    }
  }
}
