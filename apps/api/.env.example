# Server
NODE_ENV=development
PORT=3001

# PostgreSQL — matches the docker-compose service
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=dcredit
DATABASE_USER=dcredit
DATABASE_PASSWORD=dcredit_dev_password

# Full connection URL (alternative to individual vars)
DATABASE_URL=postgresql://dcredit:dcredit_dev_password@localhost:5432/dcredit

# SMTP — Mailpit for local dev (real credentials in production)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dcredit.local

# Web app URL (used for CORS and email links)
WEB_URL=http://localhost:5173

# JWT (add when auth is implemented)
# JWT_SECRET=change_this_in_production
# JWT_EXPIRES_IN=7d
