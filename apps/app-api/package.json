{
  "name": "@dcredit/app-api",
  "version": "0.0.1",
  "description": "dCredit customer-facing NestJS API",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "node --require ts-node/register/transpile-only --require tsconfig-paths/register src/main.ts",
    "start:dev": "node --require ts-node/register/transpile-only --require tsconfig-paths/register src/main.ts",
    "start:debug": "node --inspect --require ts-node/register/transpile-only --require tsconfig-paths/register src/main.ts",
    "start:prod": "node dist/apps/app-api/src/main.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.0",
    "@dcredit/backend-shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.17"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
