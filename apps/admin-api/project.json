{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "admin-api",
  "projectType": "application",
  "root": "apps/admin-api",
  "sourceRoot": "apps/admin-api/src",
  "implicitDependencies": ["backend-shared", "core", "types"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/admin-api/dist"],
      "options": {
        "cwd": "apps/admin-api",
        "command": "pnpm build"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin-api",
        "command": "pnpm start:dev"
      }
    },
    "start-prod": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin-api",
        "command": "pnpm start:prod"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/admin-api",
        "command": "pnpm typecheck"
      }
    }
  }
}
