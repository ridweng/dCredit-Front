# Server
NODE_ENV=development
PORT=3002
DATABASE_LOGGING=false
DATABASE_SSL=false

# PostgreSQL — shared database
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=dcredit
DATABASE_USER=dcredit
DATABASE_PASSWORD=dcredit_dev_password
DATABASE_URL=postgresql://dcredit:dcredit_dev_password@localhost:5433/dcredit

# Shared auth / mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@dcredit.local
JWT_SECRET=dev-only-change-me-secret
JWT_EXPIRES_IN=1h

# Origins / docs
APP_API_URL=http://localhost:3002
APP_WEB_URL=http://localhost:5173
ADMIN_UI_ORIGIN=http://localhost:3002
CORS_ORIGINS=http://localhost:3002,http://localhost:5173
